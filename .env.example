# 🌐 Server Settings
PORT=5000
NODE_ENV=production
APP_NAME=DukanDost Pro

# 🗄️ Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dukandost?retryWrites=true&w=majority

# 🔑 Auth
JWT_SECRET=your_super_secret_jwt_key

# 🤖 AI Assistant (Agents Router - Free)
AGENT_ROUTER_API_KEY=your_agent_router_api_key
AGENT_ROUTER_BASE_URL=https://api.agentsrouter.com/v1
AI_MODEL=meta-llama/llama-3-8b-instruct:free

# 💳 Payments (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# 📧 Sentry (Optional for monitoring)
SENTRY_DSN=your_sentry_dsn

# 📨 Cloudinary (For image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 🌐 Frontend (Only needed if separate deployment)
FRONTEND_URL=https://your-frontend-url.vercel.app
